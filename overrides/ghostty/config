# Personal overrides on top of hendrikmi XDG config

command = zsh --login

# Dark glass (Phase 10 — manishprivet 스타일 매칭)
window-decoration = false
macos-titlebar-style = hidden

# 한/영 cell 폭 완벽 정렬을 위해 Sarasa Mono K 단일 폰트 (Iosevka 기반 영문 + 본고딕 한글)
font-family = "Sarasa Mono K"

background = 000000
background-opacity = 0.5
background-blur = 20

# 드래그 선택만으로 복사되지 않게 (Cmd+C로 명시 복사)
copy-on-select = false
